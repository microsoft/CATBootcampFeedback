FROM node:20-slim

WORKDIR /home/site/wwwroot

# Copy package files and install deps + express for local dev server
COPY package.json package-lock.json* ./
RUN npm ci --production && npm install express

# Copy function code
COPY host.json ./
COPY src/ ./src/

EXPOSE 80

# server.js is mounted via docker-compose volumes
CMD ["node", "server.js"]
