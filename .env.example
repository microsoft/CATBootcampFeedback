# Azure SQL Database Configuration
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=CATBootcampFeedback
SQL_USER=your-admin-username
SQL_PASSWORD=your-secure-password

# Application Insights (Optional)
APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# Environment
NODE_ENV=production

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-app.azurestaticapps.net

# Admin Configuration
# ADMIN_USERS_JSON is still supported as a fallback during migration,
# but users are now managed in the database Users table.
# Run migrations/002-add-user-management.sql then scripts/migrate-users-from-env.js
# to migrate existing users to the database.
ADMIN_USERS_JSON=[{"username":"admin","passwordHash":"$2b$10$...","fullName":"Admin","email":"admin@example.com"}]

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=8h

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=3600000
